---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — GH Agentic Workflows" currentPage="">
  <section class="hero" style="min-height: 60vh;">
    <div class="hero-content">
      <div class="hero-emoji">🔍</div>
      <h1 class="hero-title">Page Not Found</h1>
      <p class="hero-subtitle">The page you're looking for doesn't exist or has been moved.</p>
      <div class="hero-buttons">
        <a href={import.meta.env.BASE_URL} class="btn btn-primary">← Back to Home</a>
      </div>
    </div>
  </section>
</BaseLayout>
