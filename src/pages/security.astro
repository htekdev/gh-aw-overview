---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'security');
const { Content } = await entry.render();

const { title, description, heroEmoji, heroSubtitle, accentColor } = entry.data;
---

<BaseLayout title={title} description={description} currentPage="security">
  <header class="hero">
    <div class="hero-content">
      <div class="hero-emoji">{heroEmoji}</div>
      <h1 class="hero-title">{entry.data.navLabel}</h1>
      <p class="hero-subtitle">{heroSubtitle}</p>
    </div>
  </header>

  <div class="container mdx-content">
    <Content />
  </div>
</BaseLayout>
