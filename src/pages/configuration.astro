---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'configuration');
if (!entry) throw new Error('Content entry not found: pages/configuration');
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description} currentPage="configuration">
  <header class="page-hero">
    <div class="hero-content">
      <div class="hero-emoji">{entry.data.heroEmoji}</div>
      <h1 class="hero-title">Configuration Reference</h1>
      <p class="hero-subtitle">{entry.data.heroSubtitle}</p>
    </div>
  </header>

  <div class="container mdx-content">
    <Content />
  </div>
</BaseLayout>
