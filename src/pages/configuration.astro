---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'configuration');
if (!entry) throw new Error('Content entry not found: pages/configuration');
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description} currentPage="configuration">
  <div class="page-hero">
    <div class="container">
      <div class="page-hero-content">
        <span class="page-hero-emoji">{entry.data.heroEmoji}</span>
        <h1 class="page-hero-title">Configuration Reference</h1>
        <p class="page-hero-subtitle">{entry.data.heroSubtitle}</p>
      </div>
    </div>
  </div>

  <div class="container mdx-content">
    <Content />
  </div>
</BaseLayout>
