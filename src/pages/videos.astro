---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'videos');
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description} currentPage="videos">
  <header class="page-hero">
    <div class="hero-content">
      <div class="hero-emoji">🎥</div>
      <h1 class="hero-title">Videos</h1>
      <p class="hero-subtitle">{entry.data.heroSubtitle}</p>
    </div>
  </header>

  <div class="container mdx-content">
    <Content />
  </div>
</BaseLayout>
