    <line x1="140" y1="145" x2="278" y2="152" stroke="#fbbf24" stroke-width="1.5" stroke-dasharray="5,3" marker-end="url(#evo-arr-y)" opacity="0.4"></line>
    <line x1="140" y1="155" x2="278" y2="155" stroke="#fbbf24" stroke-width="2" marker-end="url(#evo-arr-y)"></line>
