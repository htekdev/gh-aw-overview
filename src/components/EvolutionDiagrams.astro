    <!-- Ideas -->
    <text x="75" y="55" fill="#fbbf24" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui">💡 IDEAS</text>
    <rect x="15" y="68" width="120" height="26" rx="6" fill="rgba(251,191,36,0.06)" stroke="rgba(251,191,36,0.3)" stroke-width="1"></rect>
    <text x="75" y="86" fill="#fbbf24" text-anchor="middle" font-size="10" font-family="system-ui">"Refactor auth"</text>
    <rect x="15" y="100" width="120" height="26" rx="6" fill="rgba(251,191,36,0.06)" stroke="rgba(251,191,36,0.3)" stroke-width="1"></rect>
    <text x="75" y="118" fill="#fbbf24" text-anchor="middle" font-size="10" font-family="system-ui">"Add caching"</text>
    <rect x="15" y="132" width="120" height="26" rx="6" fill="rgba(251,191,36,0.06)" stroke="rgba(251,191,36,0.3)" stroke-width="1"></rect>
    <text x="75" y="150" fill="#fbbf24" text-anchor="middle" font-size="10" font-family="system-ui">"Fix perf issue"</text>
    <rect x="15" y="164" width="120" height="26" rx="6" fill="rgba(251,191,36,0.06)" stroke="rgba(251,191,36,0.3)" stroke-width="1"></rect>
    <text x="75" y="182" fill="#fbbf24" text-anchor="middle" font-size="10" font-family="system-ui">"New endpoints"</text>
    <!-- Arrows to core -->
