---
/**
 * SVG diagrams for the DevOps evolution timeline on the homepage.
 * Adapted from htek.dev/agentic-devops — four phases + summary.
 * Use the `phase` prop to render a specific diagram.
 */
interface Props {
  phase: 'linear' | 'loop' | 'collapsed' | 'continuous-ai' | 'summary';
}
const { phase } = Astro.props;
---

{phase === 'linear' && (
<div class="evo-diagram">
  <svg viewBox="0 0 800 130" xmlns="http://www.w3.org/2000/svg" class="evo-svg">
    <defs>
      <marker id="evo-arr-r" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#f87171"></polygon>
      </marker>
    </defs>
    <rect x="10" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"></rect>
    <text x="75" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Plan</text>
    <text x="75" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">2-3 months</text>
    <rect x="170" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"></rect>
    <text x="235" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Develop</text>
    <text x="235" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">3-6 months</text>
    <rect x="330" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"></rect>
    <text x="395" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Test</text>
    <text x="395" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">1-2 months</text>
    <rect x="490" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"></rect>
    <text x="555" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Deploy</text>
    <text x="555" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">1-2 weeks</text>
    <rect x="650" y="30" width="130" height="48" rx="8" fill="rgba(248,113,113,0.06)" stroke="#f87171" stroke-width="1.5"></rect>
    <text x="715" y="52" fill="#f87171" text-anchor="middle" font-size="13" font-weight="600" font-family="system-ui">Feedback</text>
    <text x="715" y="68" fill="rgba(248,113,113,0.6)" text-anchor="middle" font-size="10" font-family="system-ui">Too late</text>
    <line x1="140" y1="54" x2="168" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"></line>
    <line x1="300" y1="54" x2="328" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"></line>
    <line x1="460" y1="54" x2="488" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"></line>
    <line x1="620" y1="54" x2="648" y2="54" stroke="#f87171" stroke-width="1.5" marker-end="url(#evo-arr-r)"></line>
    <line x1="10" y1="100" x2="780" y2="100" stroke="rgba(248,113,113,0.2)" stroke-width="1" stroke-dasharray="4"></line>
    <text x="395" y="120" fill="#f87171" text-anchor="middle" font-size="12" font-weight="600" font-family="system-ui">6-12 months per release</text>
  </svg>
</div>
)}

{phase === 'loop' && (
<div class="evo-diagram">
  <svg viewBox="0 0 700 310" xmlns="http://www.w3.org/2000/svg" class="evo-svg">
    <defs>
      <marker id="evo-arr-b" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#60a5fa"></polygon>
      </marker>
    </defs>
    <ellipse cx="350" cy="140" rx="195" ry="105" fill="none" stroke="rgba(96,165,250,0.12)" stroke-width="1.5"></ellipse>
    <g transform="translate(350,140)">
      <g transform="translate(0,-105)">
        <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Plan</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">1-2 weeks</text>
      </g>
      <g transform="translate(138,-74)">
        <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Code</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">days</text>
      </g>
      <g transform="translate(170,0)">
        <rect x="-50" y="-16" width="100" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Build &amp; Test</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">minutes (CI)</text>
      </g>
      <g transform="translate(138,74)">
        <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Release</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">hours (CD)</text>
      </g>
      <g transform="translate(0,105)">
        <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Deploy</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">minutes</text>
      </g>
      <g transform="translate(-138,74)">
        <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Operate</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">continuous</text>
      </g>
      <g transform="translate(-170,0)">
        <rect x="-42" y="-16" width="84" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Monitor</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">real-time</text>
      </g>
      <g transform="translate(-138,-74)">
        <rect x="-46" y="-16" width="92" height="32" rx="16" fill="rgba(96,165,250,0.08)" stroke="rgba(96,165,250,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="0" fill="#60a5fa" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">Feedback</text>
        <text x="0" y="12" fill="rgba(96,165,250,0.6)" text-anchor="middle" font-size="8" font-family="system-ui">immediate</text>
      </g>
      <!-- Clockwise arrows -->
      <path d="M 38,-103 Q 98,-98 126,-82" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M 172,-55 Q 188,-30 178,-8" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M 178,12 Q 188,35 172,58" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M 126,86 Q 98,103 38,105" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M -38,105 Q -98,103 -126,86" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M -172,58 Q -188,35 -178,12" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M -178,-8 Q -188,-30 -172,-55" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <path d="M -126,-82 Q -98,-98 -38,-103" fill="none" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#evo-arr-b)"></path>
      <text x="0" y="-4" fill="rgba(96,165,250,0.4)" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">CONTINUOUS</text>
      <text x="0" y="10" fill="rgba(96,165,250,0.4)" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">LOOP</text>
    </g>
    <text x="350" y="290" fill="#60a5fa" text-anchor="middle" font-size="12" font-weight="600" font-family="system-ui">Days to weeks per change — feedback is continuous</text>
  </svg>
</div>
)}

{phase === 'collapsed' && (
<div class="evo-diagram">
  <svg viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg" class="evo-svg">
    <defs>
      <marker id="evo-arr-gn" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#34d399"></polygon>
      </marker>
      <marker id="evo-arr-y" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#fbbf24"></polygon>
      </marker>
      <marker id="evo-arr-em" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#6ee7b7"></polygon>
