    <circle cx="400" cy="155" r="85" fill="none" stroke="rgba(52,211,153,0.3)" stroke-width="2"></circle>
    <g transform="translate(400, 155)">
      <g transform="translate(0, -52)">
        <rect x="-42" y="-14" width="84" height="28" rx="14" fill="rgba(52,211,153,0.1)" stroke="rgba(52,211,153,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="2" fill="#34d399" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">🔍 Research</text>
