        <text x="0" y="2" fill="#34d399" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">📋 Plan</text>
      </g>
      <g transform="translate(-46, 26)">
        <rect x="-44" y="-14" width="88" height="28" rx="14" fill="rgba(52,211,153,0.1)" stroke="rgba(52,211,153,0.4)" stroke-width="1.5"></rect>
        <text x="0" y="2" fill="#34d399" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui">⚡ Implement</text>
      </g>
      <path d="M 28,-40 Q 52,-16 48,10" fill="none" stroke="#34d399" stroke-width="1.5" marker-end="url(#evo-arr-gn)"></path>
      <path d="M 28,40 Q 0,52 -28,40" fill="none" stroke="#34d399" stroke-width="1.5" marker-end="url(#evo-arr-gn)"></path>
      <path d="M -48,10 Q -52,-16 -28,-40" fill="none" stroke="#34d399" stroke-width="1.5" marker-end="url(#evo-arr-gn)"></path>
      <text x="0" y="-10" fill="rgba(52,211,153,0.3)" text-anchor="middle" font-size="9" font-weight="700" font-family="system-ui">TIGHT</text>
      <text x="0" y="2" fill="rgba(52,211,153,0.3)" text-anchor="middle" font-size="9" font-weight="700" font-family="system-ui">LOOP</text>
