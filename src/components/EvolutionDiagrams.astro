    <g transform="translate(195, 160)">
      <g transform="translate(0, -70)">
        <rect x="-40" y="-13" width="80" height="26" rx="13" fill="rgba(192,132,252,0.08)" stroke="rgba(192,132,252,0.35)" stroke-width="1.5"></rect>
